# ═══════════════════════════════════════════════════════════════
#  Boogle Runner — environment template (Stage 11)
#
#  Copy to `.env` and fill in. The runner is BYOK: every key below is
#  YOURS. The runner never holds a Supabase service-role key — all DB
#  access is brokered by the dashboard's /api/internal/* routes.
#
#  When deploying with `docker run`, the dashboard's Settings → Runner
#  tab gives you a command with BOOGLE_DASHBOARD_URL + BOOGLE_RUNNER_TOKEN
#  pre-filled; the rest of these come from this file via --env-file .env.
# ═══════════════════════════════════════════════════════════════

# ── Connection to the Boogle dashboard ──────────────────────────
# Your dashboard origin (e.g. https://app.boogle.com). No trailing slash.
BOOGLE_DASHBOARD_URL=
# Issued in Settings → Runner ("Generate runner token"). Shown once.
# Authenticates the worker's job polling (x-runner-token).
BOOGLE_RUNNER_TOKEN=
# Authenticates the pipeline scripts' /api/internal/* calls.
BOOGLE_INTERNAL_TOKEN=
# Your Boogle user id (scopes all brokered DB access to your account).
BOOGLE_USER_ID=
# Optional — worker poll cadence in ms. Default 10000 (10s).
# WORKER_POLL_INTERVAL_MS=10000

# ── AI services (BYOK) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=
ASSEMBLYAI_API_KEY=
APIFY_API_KEY=
# Google Gemini (AI Studio) — image generation for carousel/image/story
# posts ("Nano Banana", gemini-2.5-flash-image). Only needed if you produce
# non-video content types. Get a key at aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Posting ─────────────────────────────────────────────────────
AYRSHARE_API_KEY=
# Comma-separated, e.g. tiktok,instagram,youtube
POSTING_PLATFORMS=
# true = hold for approval in the dashboard before posting
POST_APPROVAL=true
# true = post the moment a piece is approved (else schedule by POST_TIME)
POST_IMMEDIATELY=false
# IANA tz, e.g. Asia/Colombo
POST_TIMEZONE=
# HH:MM local time to schedule posts when POST_IMMEDIATELY=false
POST_TIME=

# ── Brand / content config ──────────────────────────────────────
NICHE=
PRIMARY_AUDIENCE=
TARGET_COUNTRY=
TARGET_LANGUAGE=
AUDIENCE_GENDER=
AUDIENCE_AGE_RANGE=
AUDIENCE_PAIN_POINTS=
AUDIENCE_ASPIRATIONS=
TONE=
# Comma-separated topics to avoid
BANNED_TOPICS=
# Comma-separated handles/names to emulate
REFERENCE_CREATORS=
# Caption preset, e.g. bold-center
CAPTION_STYLE=

# ── Trend scraping (Apify) ──────────────────────────────────────
MONITOR_TIKTOK_HASHTAGS=
MONITOR_TIKTOK_ACCOUNTS=
MONITOR_INSTAGRAM_HASHTAGS=
MONITOR_INSTAGRAM_ACCOUNTS=
# Max posts to pull per source
SCRAPE_POSTS_LIMIT=30
# How many trend ideas to surface per day
TRENDS_PER_DAY=3

# ── Notifications ───────────────────────────────────────────────
# Optional — Telegram bot token for run/event alerts.
TELEGRAM_BOT_TOKEN=

# NOTE: BOOGLE_CONTENT_PIECE_ID and BOOGLE_BRAND_ID are injected
# per-job by the worker at runtime — do NOT set them here.
